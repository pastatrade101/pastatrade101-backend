# ─────────────────────────────────────────────────────────────
# Pastatrade Crypto Intelligence — backend environment
# Copy to backend/.env and fill in. Everything except SUPABASE_*
# has sane local defaults so the API boots without configuration.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5050
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase (Postgres). Use the SERVICE ROLE key — server-side only, never ship to the client.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth (custom JWT + RBAC, ported from tour-website)
JWT_SECRET=development-only-change-this-secret
JWT_EXPIRES_IN=7d

# ── Payments — Snippe (https://docs.snippe.sh) ──────────────
# Leave SNIPPE_API_KEY blank to disable payments (upgrades fall back to manual
# admin activation). Get keys from the Snippe dashboard. Server-side only — never
# ship these to the browser, and never commit real values.
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=
SNIPPE_BASE_URL=https://api.snippe.sh
# Public URL of THIS backend, so Snippe can reach the webhook. In production set
# this to your deployed API origin (e.g. https://api.yourapp.com).
PUBLIC_API_URL=http://localhost:5050

# ── External data sources ───────────────────────────────────
# CoinGecko: a free "Demo" key (https://www.coingecko.com/en/developers/dashboard)
# raises rate limits and unlocks market_chart history. Leave blank to use the
# keyless public tier (heavily rate-limited — fine for a first smoke test only).
COINGECKO_API_KEY=
# Pro plan? Flip this to true so requests hit pro-api.coingecko.com with the pro header.
COINGECKO_PRO=false

# On-chain metrics via BGeometrics (https://bitcoin-data.com). Free key raises
# your quota (8/hr, 15/day) — endpoints also work keyless. Blank = keyless mode.
BITCOIN_DATA_API_KEY=

# YouTube Data API v3 key (optional social source). Blank = YouTube stays "Unavailable".
# Get one at https://console.cloud.google.com → enable "YouTube Data API v3".
YOUTUBE_API_KEY=

# SerpApi key for Google Trends (preferred provider). https://serpapi.com/google-trends-api
# Blank → tries the unofficial google-trends-api scraper → else Trends stays "Pending".
SERPAPI_API_KEY=

# Twelve Data key for the Macro Regime module (dollar/equities/volatility/gold via
# free-tier ETF proxies). https://twelvedata.com — free plan is enough. Blank =
# Macro Regime stays unconfigured and is skipped gracefully in the sync.
TWELVE_DATA_API_KEY=

# DefiLlama needs no key. Override the base only if you proxy it.
DEFILLAMA_BASE_URL=https://api.llama.fi
STABLECOINS_BASE_URL=https://stablecoins.llama.fi

# Cache + sync tuning
# Default TTL (seconds) for cached upstream responses.
CACHE_TTL_SECONDS=120
# Min delay (ms) between CoinGecko calls inside a sync to respect rate limits.
COINGECKO_THROTTLE_MS=2500

# ── Scheduler ───────────────────────────────────────────────
# Auto-runs syncs while the server is up (no OS cron needed). Set to false to disable.
SCHEDULER_ENABLED=true
# Run a full + price-series + risk sync shortly after boot (off by default so
# frequent restarts don't re-hammer CoinGecko). Handy for a fresh deploy.
SCHEDULER_RUN_ON_BOOT=false
# How often each sync runs.
FULL_SYNC_INTERVAL_MIN=120
PRICE_SYNC_INTERVAL_HOURS=24
RISK_SYNC_INTERVAL_HOURS=24

